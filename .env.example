# =====================================================
# APP CONFIGURATION
# =====================================================

NODE_ENV=development

NEXT_PUBLIC_APP_NAME=LearnOS
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =====================================================
# CLERK AUTHENTICATION
# =====================================================

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# =====================================================
# DATABASE
# =====================================================

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/learnos?retryWrites=true&w=majority

DATABASE_NAME=learnos

# =====================================================
# AI
# =====================================================

AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash

GEMINI_API_KEY=your_gemini_api_key

# =====================================================
# SUPABASE STORAGE
# =====================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# =====================================================
# EMAIL
# =====================================================

RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=onboarding@resend.dev

# =====================================================
# GOOGLE OAUTH (Calendar)
# =====================================================

GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# =====================================================
# YOUTUBE DATA API
# =====================================================

YOUTUBE_API_KEY=your_youtube_api_key

# =====================================================
# FILE UPLOADS
# =====================================================

UPLOAD_MAX_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,ppt,pptx,doc,docx,txt,md

# =====================================================
# FEATURE FLAGS
# =====================================================

ENABLE_AI=true
ENABLE_AI_MENTOR=true
ENABLE_DIAGNOSTIC_ASSESSMENT=true

ENABLE_ASSIGNMENTS=true
ENABLE_QUIZZES=true
ENABLE_PROGRESS_TRACKING=true

ENABLE_UPLOADS=true
ENABLE_YOUTUBE_IMPORT=true

ENABLE_CALENDAR=true
ENABLE_EMAILS=true
ENABLE_NOTIFICATIONS=true

ENABLE_COMMUNITY=true

ENABLE_MARKETPLACE=false
ENABLE_STUDY_PARTNER=false